generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EmploymentType {
  full_time
  part_time
  contract
  intern
}

enum EmploymentStatus {
  active
  on_leave
  suspended
  terminated
}

enum AttendanceStatus {
  present
  absent
  half_day
  weekend
  holiday
}

enum LeaveStatus {
  pending
  approved
  rejected
  cancelled
  revoked
}

enum PayrollRunStatus {
  draft
  processing
  processed
  approved
  paid
}

enum PayrollComponentType {
  earning
  deduction
  statutory
}

enum CalculationType {
  fixed
  percentage
  formula
}

model Tenant {
  /// UUID primary key for platform tenant metadata.
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  schema    String   @unique
  region    String
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users     User[]
  auditLogs AuditLog[]

  @@map("tenants")
}

model User {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  email           String
  passwordHash    String    @map("password_hash")
  mfaEnabled      Boolean   @default(false) @map("mfa_enabled")
  encryptedTotp   String?   @map("encrypted_totp")
  failedAttempts  Int       @default(0) @map("failed_attempts")
  lockedUntil     DateTime? @map("locked_until")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  employee        Employee?
  sessions        Session[]
  refreshTokens   RefreshToken[]
  roles           UserRole[]

  @@unique([tenantId, email])
  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  ip        String?
  userAgent String?  @map("user_agent")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id])

  @@index([tenantId, userId])
  @@map("sessions")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt])
  @@map("refresh_tokens")
}

model Role {
  id          String           @id @default(uuid())
  tenantId    String           @map("tenant_id")
  code        String
  name        String
  permissions RolePermission[]
  users       UserRole[]

  @@unique([tenantId, code])
  @@map("roles")
}

model Permission {
  id    String           @id @default(uuid())
  code  String           @unique
  name  String
  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

model Department {
  id        String     @id @default(uuid())
  tenantId  String     @map("tenant_id")
  name      String
  code      String
  employees Employee[]

  @@unique([tenantId, code])
  @@map("departments")
}

model Designation {
  id        String     @id @default(uuid())
  tenantId  String     @map("tenant_id")
  name      String
  code      String
  employees Employee[]

  @@unique([tenantId, code])
  @@map("designations")
}

model Grade {
  id        String     @id @default(uuid())
  tenantId  String     @map("tenant_id")
  name      String
  code      String
  employees Employee[]

  @@unique([tenantId, code])
  @@map("grades")
}

model Location {
  id        String     @id @default(uuid())
  tenantId  String     @map("tenant_id")
  name      String
  code      String
  country   String
  timezone  String
  currency  String
  employees Employee[]

  @@unique([tenantId, code])
  @@map("locations")
}

model CostCenter {
  id        String     @id @default(uuid())
  tenantId  String     @map("tenant_id")
  name      String
  code      String
  employees Employee[]

  @@unique([tenantId, code])
  @@map("cost_centers")
}

model Employee {
  id                    String           @id @default(uuid())
  tenantId              String           @map("tenant_id")
  employeeCode          String           @map("employee_code")
  userId                String?          @unique @map("user_id")
  firstName             String           @map("first_name")
  middleName            String?          @map("middle_name")
  lastName              String           @map("last_name")
  dateOfBirth           DateTime?        @map("date_of_birth")
  gender                String?
  maritalStatus         String?          @map("marital_status")
  nationality           String?
  bloodGroup            String?          @map("blood_group")
  personalEmail         String           @map("personal_email")
  workEmail             String           @map("work_email")
  phone                 String?
  emergencyContact      Json?            @map("emergency_contact")
  profilePhotoUrl       String?          @map("profile_photo_url")
  joiningDate           DateTime         @map("joining_date")
  confirmationDate      DateTime?        @map("confirmation_date")
  probationEndDate      DateTime?        @map("probation_end_date")
  employmentType        EmploymentType   @map("employment_type")
  employmentStatus      EmploymentStatus @map("employment_status")
  departmentId          String           @map("department_id")
  designationId         String           @map("designation_id")
  gradeId               String           @map("grade_id")
  locationId            String           @map("location_id")
  costCenterId          String           @map("cost_center_id")
  reportingManagerId    String?          @map("reporting_manager_id")
  dottedLineManagerId   String?          @map("dotted_line_manager_id")
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")
  deletedAt             DateTime?        @map("deleted_at")

  user                  User?            @relation(fields: [userId], references: [id])
  department            Department       @relation(fields: [departmentId], references: [id])
  designation           Designation      @relation(fields: [designationId], references: [id])
  grade                 Grade            @relation(fields: [gradeId], references: [id])
  location              Location         @relation(fields: [locationId], references: [id])
  costCenter            CostCenter       @relation(fields: [costCenterId], references: [id])

  @@unique([tenantId, employeeCode])
  @@index([tenantId, employmentStatus])
  @@index([departmentId])
  @@index([locationId])
  @@map("employees")
}

model AttendanceRecord {
  id                 String           @id @default(uuid())
  tenantId           String           @map("tenant_id")
  employeeId         String           @map("employee_id")
  date               DateTime
  clockIn            DateTime?        @map("clock_in")
  clockOut           DateTime?        @map("clock_out")
  clockInSource      String?          @map("clock_in_source")
  totalHours         Decimal          @default(0) @map("total_hours")
  overtimeHours      Decimal          @default(0) @map("overtime_hours")
  status             AttendanceStatus
  regularizationId   String?          @map("regularization_request_id")
  approvedBy         String?          @map("approved_by")
  approvedAt         DateTime?        @map("approved_at")

  @@unique([tenantId, employeeId, date])
  @@index([tenantId, date, status])
  @@map("attendance_records")
}

model LeaveType {
  id                String @id @default(uuid())
  tenantId          String @map("tenant_id")
  name              String
  code              String
  isPaid            Boolean @map("is_paid")
  carryForwardLimit Decimal? @map("carry_forward_limit")
  encashable        Boolean @default(false)
  genderRestricted  String? @map("gender_restricted")

  @@unique([tenantId, code])
  @@map("leave_types")
}

model LeaveBalance {
  id          String  @id @default(uuid())
  tenantId    String  @map("tenant_id")
  employeeId  String  @map("employee_id")
  leaveTypeId String  @map("leave_type_id")
  year        Int
  opening     Decimal
  accrued     Decimal
  taken       Decimal
  pending     Decimal
  closing     Decimal

  @@unique([tenantId, employeeId, leaveTypeId, year])
  @@map("leave_balances")
}

model LeaveRequest {
  id             String      @id @default(uuid())
  tenantId       String      @map("tenant_id")
  employeeId     String      @map("employee_id")
  leaveTypeId    String      @map("leave_type_id")
  fromDate       DateTime    @map("from_date")
  toDate         DateTime    @map("to_date")
  durationDays   Decimal     @map("duration_days")
  reason         String
  status         LeaveStatus
  attachmentUrl  String?     @map("attachment_url")
  approverChain  Json        @map("approver_chain")
  currentLevel   Int         @default(1) @map("current_level")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  @@index([tenantId, employeeId, status])
  @@map("leave_requests")
}

model PayrollComponent {
  id                String               @id @default(uuid())
  tenantId          String               @map("tenant_id")
  name              String
  code              String
  type              PayrollComponentType
  calculationType   CalculationType      @map("calculation_type")
  isTaxable         Boolean              @default(false) @map("is_taxable")
  formulaExpression String?              @map("formula_expression")

  @@unique([tenantId, code])
  @@map("payroll_components")
}

model PayrollRun {
  id              String           @id @default(uuid())
  tenantId        String           @map("tenant_id")
  month           Int
  year            Int
  status          PayrollRunStatus
  triggeredBy     String           @map("triggered_by")
  triggeredAt     DateTime         @default(now()) @map("triggered_at")
  approvedBy      String?          @map("approved_by")
  approvedAt      DateTime?        @map("approved_at")
  totalGross      Decimal          @default(0) @map("total_gross")
  totalDeductions Decimal          @default(0) @map("total_deductions")
  totalNet        Decimal          @default(0) @map("total_net")
  employeeCount   Int              @default(0) @map("employee_count")
  items           PayrollRunItem[]

  @@unique([tenantId, month, year])
  @@map("payroll_runs")
}

model PayrollRunItem {
  id         String     @id @default(uuid())
  runId      String     @map("run_id")
  employeeId String     @map("employee_id")
  components Json
  gross      Decimal
  tax        Decimal
  net        Decimal
  payslipUrl String?    @map("payslip_url")
  run        PayrollRun @relation(fields: [runId], references: [id])

  @@unique([runId, employeeId])
  @@map("payroll_run_items")
}

model WorkflowRequest {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  moduleType   String   @map("module_type")
  resourceId   String   @map("resource_id")
  requesterId  String   @map("requester_id")
  status       String
  currentLevel Int      @map("current_level")
  history      Json
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([tenantId, moduleType, status])
  @@map("workflow_requests")
}

model Goal {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  employeeId  String   @map("employee_id")
  title       String
  description String
  weight      Decimal
  target      String
  actual      String?
  score       Decimal?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([tenantId, employeeId])
  @@map("goals")
}

model JobRequisition {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  title         String
  departmentId  String   @map("department_id")
  gradeId       String   @map("grade_id")
  vacancies     Int
  jdUrl         String?  @map("jd_url")
  status        String
  approverChain Json     @map("approver_chain")
  approvedAt    DateTime? @map("approved_at")

  @@index([tenantId, status])
  @@map("job_requisitions")
}

model Course {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  title           String
  description     String
  type            String
  durationMinutes Int      @map("duration_minutes")
  thumbnailUrl    String?  @map("thumbnail_url")
  contentUrl      String?  @map("content_url")
  createdBy       String   @map("created_by")

  @@index([tenantId, type])
  @@map("courses")
}

model ExpenseClaim {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  employeeId  String   @map("employee_id")
  amount      Decimal
  currency    String
  status      String
  receiptUrl  String?  @map("receipt_url")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([tenantId, employeeId, status])
  @@map("expense_claims")
}

model Asset {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  type      String
  tag       String
  status    String
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([tenantId, tag])
  @@map("assets")
}

model Document {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  employeeId String    @map("employee_id")
  type       String
  url        String
  expiryDate DateTime? @map("expiry_date")
  verified   Boolean   @default(false)

  @@index([tenantId, employeeId, type])
  @@map("documents")
}

model Notification {
  id        String    @id @default(uuid())
  tenantId  String    @map("tenant_id")
  userId    String    @map("user_id")
  event     String
  channel   String
  payload   Json
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([tenantId, userId, readAt])
  @@map("notifications")
}

model Webhook {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  url       String
  secretRef String   @map("secret_ref")
  events    String[]
  enabled   Boolean  @default(true)

  @@index([tenantId, enabled])
  @@map("webhooks")
}

model FeatureFlag {
  id        String  @id @default(uuid())
  tenantId  String? @map("tenant_id")
  key       String
  enabled   Boolean @default(false)
  rules     Json

  @@unique([tenantId, key])
  @@map("feature_flags")
}

model AuditLog {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  actorId      String?  @map("actor_id")
  action       String
  resourceType String   @map("resource_type")
  resourceId   String   @map("resource_id")
  beforeValue  Json?    @map("before_value")
  afterValue   Json?    @map("after_value")
  ip           String?
  createdAt    DateTime @default(now()) @map("created_at")
  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

