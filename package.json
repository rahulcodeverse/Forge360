{
  "name": "hrms",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @hrms/database prisma generate",
    "db:migrate": "pnpm --filter @hrms/database prisma migrate deploy",
    "db:migrate:dev": "pnpm --filter @hrms/database prisma migrate dev",
    "db:seed": "pnpm --filter @hrms/database seed",
    "db:studio": "pnpm --filter @hrms/database prisma studio",
    "db:reset": "pnpm --filter @hrms/database prisma migrate reset",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/node": "^20.14.0",
    "prettier": "^3.3.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "esbuild",
      "msgpackr-extract",
      "prisma",
      "puppeteer",
      "unrs-resolver"
    ]
  }
}
