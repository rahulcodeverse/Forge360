{
  "name": "forge360-workforce-os",
  "version": "0.1.0",
  "private": true,
  "description": "Forge360 Workforce OS enterprise SaaS monorepo",
  "scripts": {
    "start": "node tools/start-local.mjs",
    "build": "npm run build:api && npm run build:web",
    "build:api": "tsc -p apps/api/tsconfig.app.json",
    "build:web": "tsc -p apps/web/tsconfig.app.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node --test tests/*.test.mjs",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/graphql": "^13.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@angular/common": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/router": "^20.0.0",
    "ng-zorro-antd": "^20.0.0",
    "rxjs": "^7.8.0",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=22"
  }
}
