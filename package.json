{
  "name": "enterprise-hrms",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "type": "module",
  "engines": {
    "node": ">=20 <23",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "corepack pnpm --parallel --filter @hrms/api --filter @hrms/web dev",
    "start:api:local": "node tools/start-api-local.mjs",
    "start:web:local": "node tools/start-web-local.mjs",
    "build": "corepack pnpm --recursive run build",
    "typecheck": "corepack pnpm --recursive run typecheck",
    "lint": "corepack pnpm --recursive run lint",
    "test": "node --test packages/hrms-core/tests/*.test.mjs",
    "db:migrate": "corepack pnpm --filter @hrms/database prisma migrate dev",
    "db:seed": "corepack pnpm --filter @hrms/database seed",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
