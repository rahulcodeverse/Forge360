# ──────────────────────────────────────────
# Application
# ──────────────────────────────────────────
NODE_ENV=development
API_PORT=3001
WEB_PORT=3000
PDF_SERVICE_PORT=3002
WORKER_CONCURRENCY=10

# ──────────────────────────────────────────
# Database (PostgreSQL)
# ──────────────────────────────────────────
DATABASE_URL="postgresql://hrms:hrms_secret@localhost:5432/hrms?schema=public"
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ──────────────────────────────────────────
# Redis
# ──────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=

# ──────────────────────────────────────────
# JWT & Auth
# ──────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
TOTP_ENCRYPTION_KEY=change_me_32_char_aes_key_here_!!

# ──────────────────────────────────────────
# Encryption (AES-256 for PII)
# ──────────────────────────────────────────
ENCRYPTION_KEY=change_me_32_char_aes_256_key_!!

# ──────────────────────────────────────────
# AWS
# ──────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=hrms-documents-dev
S3_ENDPOINT=http://localhost:9000

# ──────────────────────────────────────────
# Email (SMTP or AWS SES)
# ──────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@hrms.local

# ──────────────────────────────────────────
# Twilio (SMS / WhatsApp)
# ──────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ──────────────────────────────────────────
# Elasticsearch / OpenSearch
# ──────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=

# ──────────────────────────────────────────
# Sentry
# ──────────────────────────────────────────
SENTRY_DSN_API=
SENTRY_DSN_WEB=

# ──────────────────────────────────────────
# SAML SSO (enterprise IdP)
# ──────────────────────────────────────────
SAML_ENTRY_POINT=
SAML_ISSUER=hrms
SAML_CERT=

# ──────────────────────────────────────────
# OAuth2
# ──────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ──────────────────────────────────────────
# Rate limiting
# ──────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT_UNAUTHENTICATED=100
THROTTLE_LIMIT_AUTHENTICATED=1000

# ──────────────────────────────────────────
# Feature flags
# ──────────────────────────────────────────
ENABLE_ELASTICSEARCH=false
ENABLE_VIRUS_SCAN=false
